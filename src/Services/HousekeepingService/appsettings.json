{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=HotelOS.db",
    "Redis": "localhost:6379"
  },
  "ServiceSettings": {
    "ServiceName": "Housekeeping Service",
    "Port": 5002,
    "HealthCheckPath": "/health"
  },
  "HousekeepingSettings": {
    "DefaultCleaningDuration": "00:45:00",
    "OverdueThresholdHours": 2,
    "MaxConcurrentTasksPerHousekeeper": 1,
    "InspectionRequired": true
  }
}