{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=HotelOS_Dev.db",
    "Redis": "localhost:6379"
  },
  "ServiceSettings": {
    "ServiceName": "Room Service (Development)",
    "Port": 5003,
    "HealthCheckPath": "/health"
  },
  "RoomServiceSettings": {
    "DefaultPreparationTimeMinutes": 15,
    "DefaultDeliveryTimeMinutes": 5,
    "OverdueThresholdHours": 1,
    "MaxConcurrentOrdersPerStaff": 5,
    "AutoAssignOrders": true
  }
}