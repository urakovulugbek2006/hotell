{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=HotelOS.db",
    "Redis": "localhost:6379"
  },
  "ServiceSettings": {
    "ServiceName": "Room Service",
    "Port": 5003,
    "HealthCheckPath": "/health"
  },
  "RoomServiceSettings": {
    "DefaultPreparationTimeMinutes": 30,
    "DefaultDeliveryTimeMinutes": 10,
    "OverdueThresholdHours": 1,
    "MaxConcurrentOrdersPerStaff": 3,
    "AutoAssignOrders": false
  }
}